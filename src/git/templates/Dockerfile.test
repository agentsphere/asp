FROM python:3.12-slim

WORKDIR /tests

COPY requirements-test.txt .
RUN pip install --no-cache-dir -r requirements-test.txt

COPY tests/ ./tests/

# APP_HOST and APP_PORT are injected by the deploy_test executor
ENV APP_HOST=localhost
ENV APP_PORT=8080

CMD ["pytest", "tests/", "-v", "--tb=short", "--junitxml=/tmp/test-results.xml"]

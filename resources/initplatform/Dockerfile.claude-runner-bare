# Bare agent image: minimal base for testing the auto-setup flow.
#
# Contains only Node.js, git, and curl. The platform's setup-tools init
# container will download agent-runner and install Claude CLI at pod start.
FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash agent
USER agent
WORKDIR /workspace

# Ignore everything by default — only whitelist what Dockerfiles need.
# This keeps the build context small by excluding .git, target, node_modules, etc.
*

# Workspace root (needed for cargo workspace resolution)
!Cargo.toml
!Cargo.lock

# Rust sources
!src/
!crates/
!migrations/
!.sqlx/

# UI sources (for main Dockerfile)
!ui/

# Agent runtime assets
!mcp/
!docker/entrypoint.sh
!docker/platform-build-status.sh

# Exclude build artifacts that sneak in via whitelisted dirs
**/target/
**/node_modules/
**/*.swp
**/*.swo

  "query": "\n        SELECT pl.git_ref as \"git_ref!: String\",\n               pl.commit_sha,\n               pl.triggered_by,\n               p.name as \"project_name!: String\",\n               p.repo_path as \"repo_path!: String\"\n        FROM pipelines pl\n        JOIN projects p ON p.id = pl.project_id\n        WHERE pl.id = $1\n        ",

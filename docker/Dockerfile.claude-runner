# Agent runtime image for Claude Code sessions
# Ported from mgr/ Go prototype — tested and working
FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code

# Install MCP servers and dependencies
COPY mcp/ /usr/local/lib/mcp/
RUN cd /usr/local/lib/mcp && npm install --production

RUN useradd -m -s /bin/bash agent
USER agent
WORKDIR /workspace

COPY --chown=agent:agent docker/entrypoint.sh /usr/local/bin/entrypoint.sh
COPY --chown=agent:agent docker/platform-build-status.sh /usr/local/bin/platform-build-status
RUN chmod +x /usr/local/bin/entrypoint.sh /usr/local/bin/platform-build-status

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

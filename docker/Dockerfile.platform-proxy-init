# Combined init container: copies proxy binary + sets up iptables rules.
# Contains iptables, the platform-proxy binary, and the Rust init binary.
# Shell and package manager are removed to minimize attack surface.
FROM alpine:3.21 AS base
RUN apk add --no-cache iptables \
    && rm -rf /bin/sh /bin/ash /sbin/apk /etc/apk /lib/apk /usr/share/apk \
              /bin/busybox /usr/bin/scanelf /usr/bin/ssl_client

ARG TARGETARCH=amd64
COPY platform-proxy-init-${TARGETARCH} /platform-proxy-init
COPY platform-proxy-${TARGETARCH} /platform-proxy
ENTRYPOINT ["/platform-proxy-init"]
